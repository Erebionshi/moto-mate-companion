# ─── MotoNav Backend Environment Variables ───────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# ── MongoDB Atlas (free tier M0) ──────────────────────────────────────────────
# 1. Go to https://cloud.mongodb.com → Create a FREE M0 cluster
# 2. Database Access → Add database user (username + password)
# 3. Network Access → Add IP Address → Allow from anywhere (0.0.0.0/0)
# 4. Clusters → Connect → Drivers → Copy the connection string
#    Replace <password> with your actual password
MONGODB_URI=mongodb+srv://law:lawpassword@cluster0.rvbyrhs.mongodb.net/law-protector?retryWrites=true&w=majority

# ── Google Gemini AI (free tier) ──────────────────────────────────────────────
# 1. Go to https://aistudio.google.com/apikey
# 2. Click "Create API key" → copy below
# Free quota: 15 requests/min, 1 million tokens/min — more than enough
GEMINI_API_KEY=AIzaSy...

# ── Open-Meteo (weather) ──────────────────────────────────────────────────────
# No key needed — 100% free, no sign-up, no rate limits for non-commercial use.
