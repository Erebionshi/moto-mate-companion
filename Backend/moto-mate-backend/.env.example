# ─── MotoNav Backend ─────────────────────────────────────────────────────────
# Copy to .env and fill in your values.

# MongoDB Atlas M0 free cluster — https://cloud.mongodb.com
# Get from: Clusters → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/motoNav?retryWrites=true&w=majority

# Groq AI free tier (Llama 3) — https://console.groq.com
GROQ_API_KEY=gsk_...

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-here

# Server port (default 3001) — Render injects PORT automatically
PORT=3001

# Allowed frontend origin for CORS — set to your deployed frontend URL on Render
FRONTEND_URL=http://localhost:8080
